---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

function formatDate(date) {
  return date.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
}
---

<BaseLayout
  title={`${post.data.title} — Casa Roca Canggu`}
  description={post.data.description}
  canonical={`https://casaroca.com/blog/${post.slug}`}
>
  <Header />

  <main class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop">

    <!-- Post header -->
    <header class="pt-24 pb-12 md:pt-32 max-w-3xl">
      <span class="font-label-sm text-label-sm text-secondary uppercase tracking-widest mb-4 block">
        {post.data.category}
      </span>
      <h1 class="font-headline-xl-mobile md:font-headline-lg text-headline-xl-mobile md:text-headline-lg text-on-surface mb-6">
        {post.data.title}
      </h1>
      <p class="font-body-lg text-body-lg text-on-surface-variant mb-6">
        {post.data.description}
      </p>
      <div class="flex items-center gap-4 font-label-sm text-label-sm text-outline">
        <span>{post.data.author}</span>
        <span>·</span>
        <span>{formatDate(post.data.pubDate)}</span>
      </div>
    </header>

    <!-- Hero image -->
    {post.data.image && (
      <div class="w-full aspect-[21/9] rounded-xl overflow-hidden mb-16">
        <img
          src={post.data.image}
          alt={post.data.imageAlt}
          class="w-full h-full object-cover"
          loading="eager"
        />
      </div>
    )}

    <!-- Article content -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 mb-section-gap">
      <article class="lg:col-span-8 prose-content">
        <Content />
      </article>

      <!-- Sidebar -->
      <aside class="lg:col-span-4 space-y-8">
        <div class="bg-surface-container-low rounded-xl p-8 sticky top-32">
          <h3 class="font-label-md text-label-md text-on-surface uppercase tracking-widest mb-6">
            Stay in Canggu
          </h3>
          <p class="font-body-md text-body-md text-on-surface-variant mb-6">
            Casa Roca — 10 private rooms on Jl. Batu Bolong. 5 minutes walk to the beach.
          </p>
          <a
            href="/availability"
            class="block bg-secondary text-on-secondary px-6 py-3 rounded-lg font-label-md text-label-md text-center hover:opacity-90 transition-opacity"
          >
            Check Availability
          </a>
          <a
            href="/rooms"
            class="block border border-outline text-on-surface px-6 py-3 rounded-lg font-label-md text-label-md text-center hover:bg-surface-container transition-colors mt-3"
          >
            View Rooms
          </a>
        </div>
      </aside>
    </div>

  </main>

  <Footer />
</BaseLayout>

<style>
  /* Prose styles for markdown content */
  .prose-content h2 {
    font-family: 'Playfair Display', serif;
    font-size: 32px;
    line-height: 1.3;
    font-weight: 500;
    color: #1b1c1c;
    margin-top: 48px;
    margin-bottom: 16px;
  }
  .prose-content h3 {
    font-family: 'Playfair Display', serif;
    font-size: 24px;
    line-height: 1.3;
    font-weight: 500;
    color: #1b1c1c;
    margin-top: 32px;
    margin-bottom: 12px;
  }
  .prose-content p {
    font-size: 18px;
    line-height: 1.7;
    color: #454742;
    margin-bottom: 20px;
  }
  .prose-content ul, .prose-content ol {
    margin-left: 24px;
    margin-bottom: 20px;
  }
  .prose-content li {
    font-size: 18px;
    line-height: 1.7;
    color: #454742;
    margin-bottom: 8px;
  }
  .prose-content table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 24px;
  }
  .prose-content th {
    text-align: left;
    padding: 12px 16px;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.05em;
    color: #767872;
    border-bottom: 2px solid #77574d;
  }
  .prose-content td {
    padding: 12px 16px;
    font-size: 16px;
    color: #1b1c1c;
    border-bottom: 1px solid #c6c7c0;
  }
  .prose-content strong {
    font-weight: 600;
    color: #1b1c1c;
  }
  .prose-content a {
    color: #77574d;
    text-decoration: underline;
  }
  .prose-content hr {
    border: none;
    border-top: 1px solid #c6c7c0;
    margin: 40px 0;
  }
</style>