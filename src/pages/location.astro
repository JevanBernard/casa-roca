  title: 'Essentials',
  image: 'https://lh3.googleusercontent.com/aida-public/AB6AXuDXpYXt6ty0bTTq87yBZOfjeykR8w7jLSDecvfwdwImBDZrwlesCFqgAfcXq7oVbXBvYjYtr7PzDuCfCG92AoZz3C34GgNVoPMtjPGCYBwWawW3yBF-TkE26oocLrpxtTv8DqL-ZYt1-77SHbhoVxR8-JwsoVufDXlhga23rz1OdqDiZB6Ate2nV5JAQaqc5yEkqScEFgJ0g7pzAjr1XORgOLoyvMpRbCSPFEjI1ZAw1almMV0t1lGLigGHlzJx0UJ1-jIcZB9B308',
  imageAlt: 'Local boutique and essentials store in Canggu',
  items: [
    { name: 'Kimia Farma Pharmacy', distance: '8 min walk', mapsUrl: 'https://maps.app.goo.gl/qZz4cM4RbbBWtbzJ7' },
