---

<BaseLayout
  title="Rooms at Casa Roca Canggu - Superior & Deluxe Private Rooms in Batu Bolong"
  description="Browse Superior and Deluxe rooms at Casa Roca Canggu. All rooms include private balcony, en-suite bathroom with rain shower, AC, TV & free parking. Book direct."
  canonical="https://casaroca.com/rooms"
>

  <Header />

  <main>
    <!-- Page header -->
    <header class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop pt-32 pb-section-gap">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-gutter items-end">
        <div class="lg:col-span-8">
          <h1 class="font-headline-xl-mobile md:font-headline-xl text-headline-xl-mobile md:text-headline-xl mb-8 leading-tight">
            Private Rooms at<br />Casa Roca Batu Bolong, Canggu
          </h1>
          <p class="font-body-lg text-body-lg text-on-surface-variant max-w-2xl leading-relaxed">
            10 private rooms across two categories Superior and Deluxe on Jl. Batu Bolong,
            Canggu, Bali. Every room includes a private balcony, en-suite bathroom with rain
            shower, air conditioning, flat screen TV, and free basement parking.
          </p>
        </div>
        <div class="lg:col-span-4 flex lg:justify-end">
          <div class="lg:text-right">
            <span class="font-label-sm text-label-sm uppercase tracking-widest text-outline">
              Est. 2024
            </span>
            <div class="flex gap-1 mt-2">
              {[...Array(5)].map(() => (
                <span class="material-symbols-outlined text-secondary" style="font-variation-settings: 'FILL' 1">star</span>
              ))}
            </div>
          </div>
        </div>
      </div>
    </header>

    <!-- Jump links -->
    <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop pb-16">
      <div class="flex gap-4">
        <a
          href="#superior"
          class="border border-outline text-on-surface px-5 py-2 rounded-full font-label-md text-label-md hover:bg-surface-container transition-colors"
        >
          Superior Room
        </a>
        <a
          href="#deluxe"
          class="border border-outline text-on-surface px-5 py-2 rounded-full font-label-md text-label-md hover:bg-surface-container transition-colors"
        >
          Deluxe Room
        </a>
      </div>
    </div>

    <RoomSection {...superiorRoom} />
    <RoomSection {...deluxeRoom} />
    <RoomComparisonTable rows={comparisonRows} />
    <BentoGallery images={bentoImages} />

    <CTABanner
      title="Ready to book your room?"
      body="Direct bookings always get the lowest rate — no OTA fees, no markup. Superior and Deluxe rooms available now."
      ctaLabel="Check Availability"
      ctaHref="/availability"
    />
  </main>

  <Footer />
</BaseLayout>