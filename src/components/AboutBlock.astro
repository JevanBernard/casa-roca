---
const aboutImage =
  'https://lh3.googleusercontent.com/aida-public/AB6AXuBT8GI9xe6XOqjsZH983Gh7wZ0sPkmS-QaBxQcBzSDMs0eChK6VJR9WkyHdHWxW5Ln8db6g36zV0fhXUB_FTLk85xtkyUOzvAlYjily7R22oq2FXirymALxNg1EeWC_Fe0x56OrbznZ3Y7azVeeO__A0wK7h7Vjaj_P9oVXx2DpL09InnL0V_gWKg9Ku9CQB7wuQUeuInpBs7PGlXezmjO_yzQ9iKBC_ayQnZ_Gy7djt06q2KQOar3-9qOXhYysFr_UbqAs7sOZ2II';
---

<section class="py-section-gap px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-gutter items-center">
    <!-- Text -->
    <div class="order-2 md:order-1">
      <span class="text-secondary font-label-md text-label-md uppercase tracking-widest mb-4 block">
        Batu Bolong, Canggu
      </span>
      <h2 class="font-headline-lg text-headline-lg text-on-surface mb-8">
        What is Casa Roca Canggu?
      </h2>
      <div class="space-y-6 text-on-surface-variant font-body-lg text-body-lg leading-relaxed">
        <p>
          Casa Roca is a 10-room boutique guest house located on Jl. Batu Bolong, Canggu, Bali
          directly next to Aston Canggu Hotel. Every room includes a private balcony, en-suite rain
          shower bathroom, air conditioning, flat screen TV, and free basement parking.
        </p>
        <p>
          Built for travelers who are done with hostels and don't need a full villa, just a
          private, well-finished room in a location they can actually walk to the beach from.
          Reception is open daily 08.00–20.00 WITA.
        </p>
      </div>
      <a
        href="/about"
        class="inline-flex items-center gap-2 mt-8 text-secondary font-label-md text-label-md hover:gap-3 transition-all"
      >
        Learn more about the property
        <span class="material-symbols-outlined text-[18px]">arrow_forward</span>
      </a>
    </div>

    <!-- Image -->
    <div class="order-1 md:order-2 rounded-xl overflow-hidden aspect-[4/5] shadow-xl">
      <img
        src={aboutImage}
        alt="Casa Roca Canggu — hand-carved teak wood panels and lime plaster walls"
        class="w-full h-full object-cover"
        loading="lazy"
      />
    </div>
  </div>
</section>
