---
export interface Props {
  name: string;
  description: string;
  priceFrom: string;
  image: string;
  imageAlt: string;
  href: string;
}

const { name, description, priceFrom, image, imageAlt, href } = Astro.props;
---

<a href={href} class="group block cursor-pointer">
  <div
    class="relative aspect-[16/10] overflow-hidden rounded-xl mb-6 shadow-md transition-shadow group-hover:shadow-xl"
  >
    <img
      src={image}
      alt={imageAlt}
      class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
      loading="lazy"
    />
    <div
      class="absolute top-4 right-4 bg-white/90 backdrop-blur px-4 py-2 rounded-full font-label-sm text-label-sm text-on-surface"
    >
      from {priceFrom}/night
    </div>
  </div>

  <div class="flex justify-between items-start">
    <div>
      <h3 class="font-headline-md text-headline-md text-on-surface mb-2">{name}</h3>
      <p class="text-on-surface-variant font-body-md text-body-md max-w-md">{description}</p>
    </div>
    <span
      class="material-symbols-outlined text-secondary group-hover:translate-x-2 transition-transform mt-1 shrink-0"
    >
      arrow_forward
    </span>
  </div>
</a>
