---
export interface BentoImage {
  src: string;
  alt: string;
  caption?: string;
  colSpan?: number;
  rowSpan?: number;
}

export interface Props {
  images: BentoImage[];
}

const { images } = Astro.props;
---

<section class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop pb-section-gap">
  <div class="grid grid-cols-1 md:grid-cols-4 grid-rows-2 gap-gutter h-auto md:h-[600px]">
    {images.map(({ src, alt, caption, colSpan = 1, rowSpan = 1 }) => (
      <div
        class:list={[
          'relative rounded-xl overflow-hidden group',
          `md:col-span-${colSpan}`,
          `md:row-span-${rowSpan}`,
          rowSpan === 2 ? 'aspect-[4/5] md:aspect-auto' : 'aspect-video md:aspect-auto',
        ]}
      >
        <img
          src={src}
          alt={alt}
          class="absolute inset-0 w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110"
          loading="lazy"
        />
        {caption && (
          <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent flex items-end p-8">
            <p class="text-white font-headline-md">{caption}</p>
          </div>
        )}
      </div>
    ))}
  </div>
</section>
